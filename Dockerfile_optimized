# Stage 1: Builder
FROM pytorch/pytorch:2.4.1-cuda12.1-cudnn9-devel AS builder

ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /app

ENV PATH=/usr/local/cuda-12.2/bin:$PATH
ENV LD_LIBRARY_PATH=/usr/local/cuda-12.2/lib64:$LD_LIBRARY_PATH

# Install minimal build dependencies in a single layer
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc-9 g++-9 libgl1-mesa-glx libglib2.0-0 libgomp1 libsm6 libxext6 libxrender1 \
    libfontconfig1 libice6 curl python3-dev python3-pip cmake git autoconf automake \
    build-essential libass-dev libfreetype6-dev libgnutls28-dev libmp3lame-dev \
    libsdl2-dev libtool libva-dev libvdpau-dev libvorbis-dev libx264-dev libx265-dev \
    libnuma-dev libopus-dev libspeex-dev libvpx-dev libxfixes3 libxml2-dev \
    openssl pkg-config texinfo wget yasm zlib1g-dev nasm ocl-icd-libopencl1 \
    opencl-headers clinfo && \
    apt-get clean && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/* /var/cache/apt/*

# Clean up CUDA 12.1 from base image
RUN apt-get update && \
    (apt-get remove -y --purge "*cuda*" "*cublas*" "*cufft*" "*curand*" "*cusolver*" \
    "*cusparse*" "*npp*" "*nvjpeg*" "cuda" "nsight*" || true) && \
    rm -rf /usr/local/cuda* /var/cuda-repo-* /etc/apt/sources.list.d/cuda* && \
    apt-get clean && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/* /var/cache/apt/*

# Install CUDA 12.2 with minimal toolkit
RUN echo "debconf debconf/frontend select Noninteractive" | debconf-set-selections && \
    wget --retry-connrefused --tries=3 https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2004/x86_64/cuda-ubuntu2004.pin && \
    mv cuda-ubuntu2004.pin /etc/apt/preferences.d/cuda-repository-pin-600 && \
    wget --retry-connrefused --tries=3 https://developer.download.nvidia.com/compute/cuda/12.2.0/local_installers/cuda-repo-ubuntu2004-12-2-local_12.2.0-535.54.03-1_amd64.deb && \
    dpkg -i cuda-repo-ubuntu2004-12-2-local_12.2.0-535.54.03-1_amd64.deb && \
    cp /var/cuda-repo-ubuntu2004-12-2-local/cuda-*-keyring.gpg /usr/share/keyrings/ && \
    apt-get update && apt-get install -y --no-install-recommends cuda-toolkit-12-2 libnpp-12-2 && \
    rm cuda-repo-ubuntu2004-12-2-local_12.2.0-535.54.03-1_amd64.deb && \
    apt-get clean && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/* /var/cache/apt/*

# Verify CUDA and libnpp
RUN /usr/local/cuda-12.2/bin/nvcc --version && \
    ls /usr/local/cuda-12.2/lib64/libnpp* || { echo "libnpp not found"; exit 1; }

# Install FFmpeg nv-codec-headers
RUN git clone --depth 1 https://git.videolan.org/git/ffmpeg/nv-codec-headers.git /tmp/nv-codec-headers && \
    cd /tmp/nv-codec-headers && make install PREFIX=/usr/local && \
    cd /tmp && rm -rf /tmp/nv-codec-headers

# Build FFmpeg 8.0
RUN wget --retry-connrefused --tries=3 https://ffmpeg.org/releases/ffmpeg-8.0.tar.xz && \
    tar xvf ffmpeg-8.0.tar.xz && rm ffmpeg-8.0.tar.xz && \
    cd ffmpeg-8.0 && \
    PKG_CONFIG_PATH=/usr/local/lib/pkgconfig:/usr/local/cuda-12.2/lib64/pkgconfig \
    ./configure \
        --enable-nonfree --enable-cuda-nvcc --enable-libnpp --enable-libxml2 \
        --enable-openssl --extra-cflags=-I/usr/local/include \
        --extra-ldflags="-L/usr/local/cuda-12.2/lib64" \
        --extra-libs="-lnppial -lnppicc -lnppicom -lnppidei -lnppif -lnppig -lnppim -lnppist -lnppisu -lnppitc -lnppc -lnpps" \
        --enable-shared --disable-static --enable-ffnvcodec --enable-nvdec \
        --enable-nvenc --enable-cuvid --enable-libx264 --enable-libx265 \
        --enable-libvpx --enable-libopus --enable-gpl && \
    make -j$(nproc) && make install && \
    cd /tmp && rm -rf /tmp/ffmpeg-8.0

# Install PyAV
RUN git clone --depth 1 https://github.com/PyAV-Org/PyAV.git /tmp/PyAV && \
    cd /tmp/PyAV && \
    sed -i 's/license = "BSD-3-Clause"/license = { file = "LICENSE" }/' pyproject.toml && \
    pip install --no-cache-dir cython setuptools wheel && \
    CFLAGS="-O0 -Wno-incompatible-pointer-types -Wno-unreachable-code" python setup.py build_ext --inplace && \
    pip install . && \
    cd /tmp && rm -rf /tmp/PyAV

# Install PyNvCodec
RUN git clone --depth 1 https://github.com/NVIDIA/VideoProcessingFramework.git /tmp/VideoProcessingFramework && \
    cd /tmp/VideoProcessingFramework && mkdir build && cd build && \
    cmake .. -DCMAKE_INSTALL_PREFIX=/usr/local \
             -DFFMPEG_ROOT=/usr/local \
             -DPYTHON_INCLUDE_DIR=$(python3 -c "from distutils.sysconfig import get_python_inc; print(get_python_inc())") \
             -DPYTHON_LIBRARY=$(python3 -c "import distutils.sysconfig as sysconfig; print(sysconfig.get_config_var('LIBDIR'))") && \
    make -j$(nproc) && make install && \
    cd /tmp/VideoProcessingFramework && pip install .[samples] && \
    cd /tmp && rm -rf /tmp/VideoProcessingFramework

# Install OpenVINO and gdown
RUN pip install --no-cache-dir openvino-dev[onnx,tensorflow2,pytorch,caffe]==2024.2.0 gdown && \
    apt-get update && apt-get install -y --no-install-recommends clinfo && \
    apt-get clean && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/* /var/cache/apt/* && \
    mkdir -p /opt/intel/openvino_2024 && \
    /opt/intel/openvino_2024/setupvars.sh || true

# Create model directories
RUN mkdir -p models/AlphaPose/pretrained_models \
    models/OpenVINO/pretrained_models/public/human-pose-estimation-0007/FP32 \
    models/OpenVINO/pretrained_models/public/human-pose-estimation-0006/FP32 \
    models/OpenVINO/pretrained_models/public/human-pose-estimation-0005/FP32 \
    models/OpenVINO/pretrained_models/intel/human-pose-estimation-0001 \
    models/MoveNet

# Download models
RUN gdown --id 1p6bi10UybpUIcq5D2XDsgQRLPJIr2RyI -O models/AlphaPose/pretrained_models/fast_res50_256x192.pth && \
    gdown --id 1k-9cUGcdH5ZFN1NcMvZrO0ApW241tboD -O models/AlphaPose/detector/yolo/data/yolov3-spp.weights && \
    gdown --id 15SZwY2jAh1KqHwT-YO6_UByOsQD70RSr -O models/MoveNet/movenet_multipose_lightning_256x256_FP32.bin && \
    gdown --id 1VNucIyIsdaiw1cYt-JGqBWloVu2TVdsm -O models/OpenVINO/pretrained_models/intel/human-pose-estimation-0001/human-pose-estimation-0001.bin && \
    gdown --id 1ZSdsqgQnWHVymQoZvaXuDFcnOyEEKsexP -O models/OpenVINO/pretrained_models/public/human-pose-estimation-0005/FP32/human-pose-estimation-0005.bin && \
    gdown --id 1fko47eVczJZQb9wWA2X7eQ0TuF4PDXzs -O models/OpenVINO/pretrained_models/public/FP32/higher-hrnet-w32-human-pose-estimation.bin

# Build AlphaPose extensions and clean up
COPY models/AlphaPose /app/models/AlphaPose
RUN bash models/AlphaPose/build_extensions.sh && \
    rm -rf /app/models/AlphaPose/build /app/models/AlphaPose/*.o /app/models/AlphaPose/*.so

# Stage 2: Runtime
FROM pytorch/pytorch:2.4.1-cuda12.1-cudnn9-devel

ENV DEBIAN_FRONTEND=noninteractive
ENV TORCH_CUDA_ARCH_LIST=8.6
ENV PKG_CONFIG_PATH=/usr/local/lib/pkgconfig:/usr/local/cuda-12.2/lib64/pkgconfig
ENV PATH=/usr/local/cuda-12.2/bin:$PATH
ENV LD_LIBRARY_PATH=/usr/local/cuda-12.2/lib64:$LD_LIBRARY_PATH

WORKDIR /app

# Install minimal runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1-mesa-glx libglib2.0-0 libgomp1 libsm6 libxext6 libxrender1 \
    libfontconfig1 libice6 libxml2 openssl clinfo \
    cuda-toolkit-12-2 libnpp-12-2 && \
    apt-get clean && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/* /var/cache/apt/*

# Copy built artifacts from builder
COPY --from=builder /usr/local /usr/local
COPY --from=builder /opt/intel/openvino_2024 /opt/intel/openvino_2024
COPY --from=builder /app/models /app/models

# Copy application files
COPY . /app

# Create PID directory
RUN mkdir -p /pids && chmod 777 /pids

# Copy and set entrypoint
COPY entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

# Set entrypoint and command
ENTRYPOINT ["/app/entrypoint.sh"]
CMD ["python3", "main.py"]