# Ignore Python cache and environment files
__pycache__/
*.pyc
*.pyo
*.pyd
*.swp
*.swo
*.bak
*.tmp
*.log
.DS_Store
.env

# Ignore local virtual environments
myenv/

# Ignore build and distribution artifacts
*.egg-info/
.eggs/
build/
dist/
.cache/

# Ignore version control and editor files
.git/
