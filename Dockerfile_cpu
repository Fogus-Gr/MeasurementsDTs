# Dockerfile_cpu — CPU-only HPE container (no GPU, no PyNvCodec)
#
# Same CUDA devel base as Dockerfile_base so AlphaPose extensions can still
# compile (nvcc ships inside the devel image), but PyNvCodec is skipped
# because it requires NVIDIA driver libraries at runtime.
# Video decoding falls back to OpenCV cv2.VideoCapture automatically
# (handled by base_hpe.py try/except ImportError on PyNvCodec).
#
# Build:  docker build -t hpe-cpu -f Dockerfile_cpu .
# Usage:  docker run --rm hpe-cpu python3 main.py --method movenet --input video.mp4 --device CPU
FROM pytorch/pytorch:2.4.1-cuda12.1-cudnn9-devel

ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /app

# Create PID directory and set permissions
RUN mkdir -p /pids && chmod 777 /pids

# Copy entrypoint script first and make it executable
COPY entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

# Copy the rest of the application
COPY . /app

RUN apt-get update && apt-get install -y \
    gcc-9 g++-9 \
    libgl1-mesa-glx \
    libglib2.0-0 \
    libgomp1 \
    libsm6 \
    libxext6 \
    libxrender-dev \
    libfontconfig1 \
    libice6 \
    curl \
    iputils-ping \
    dnsutils \
    python3-tk \
    ffmpeg \
    libavfilter-dev \
    libavformat-dev \
    libavcodec-dev \
    libswresample-dev \
    libavutil-dev \
    tcpdump \
    cmake \
    git \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir -r requirements.txt
RUN pip3 install --no-cache-dir gdown

# --- PyNvCodec build SKIPPED ---
# PyNvCodec (VideoProcessingFramework) requires NVIDIA driver libraries at
# runtime.  On a CPU-only host it cannot import, so we skip the build entirely.
# base_hpe.py handles the missing import gracefully:
#   try: import PyNvCodec as nvc
#   except ImportError: nvc = None  # falls back to OpenCV cv2.VideoCapture

# Install OpenVINO with CPU support
RUN pip3 install --no-cache-dir openvino-dev[onnx,tensorflow2,pytorch,caffe]==2024.4.0

ENV TORCH_CUDA_ARCH_LIST=8.6

# Create all necessary directories
RUN mkdir -p models/OpenVINO/pretrained_models/public/human-pose-estimation-0007/FP32 && \
    mkdir -p models/OpenVINO/pretrained_models/public/human-pose-estimation-0006/FP32 && \
    mkdir -p models/OpenVINO/pretrained_models/public/human-pose-estimation-0005/FP32 && \
    mkdir -p models/OpenVINO/pretrained_models/public/FP32 && \
    mkdir -p models/OpenVINO/pretrained_models/intel/human-pose-estimation-0001

# Download models
RUN gdown --id 1p6bi10UybpUIcq5D2XDsgQRLPJIr2RyI -O models/AlphaPose/pretrained_models/fast_res50_256x192.pth && \
    gdown --id 1D47msNOOiJKvPOXlnpyzdKA3k6E97NTC -O models/AlphaPose/detector/yolo/data/yolov3-spp.weights && \
    gdown --id 15SZwY2jAh1KqHwT-YO6_UByOsQD70RSr -O models/MoveNet/movenet_multipose_lightning_256x256_FP32.bin && \
    gdown --id 1VNucIyIsdaiw1cYt-JGqBWloVu2TVdsm -O models/OpenVINO/pretrained_models/intel/human-pose-estimation-0001/human-pose-estimation-0001.bin && \
    gdown --id 1ZSdsqgD4zUO4gyHMYBfxq3m4UMyQ187j -O models/OpenVINO/pretrained_models/public/human-pose-estimation-0007/FP32/human-pose-estimation-0007.bin && \
    gdown --id 1d8pGQrM9vEfz_oAIey0qRr7Gxp6dS2UE -O models/OpenVINO/pretrained_models/public/human-pose-estimation-0006/FP32/human-pose-estimation-0006.bin && \
    gdown --id 1lEUFqQnWHVymQoZvaXuDFcnOyEEKsexP -O models/OpenVINO/pretrained_models/public/human-pose-estimation-0005/FP32/human-pose-estimation-0005.bin && \
    gdown --id 1fko47eVczJZQb9wWA2X7eQ0TuF4PDXzs -O models/OpenVINO/pretrained_models/public/FP32/higher-hrnet-w32-human-pose-estimation.bin

# Build AlphaPose C/C++/Cython extensions.
# nvcc is available in the devel image so CUDA extensions compile fine even
# without a GPU present.  At runtime with --device CPU the code uses CPU code
# paths.  If DCN fails on CPU, only --method alphapose is affected; all
# OpenVINO backends (movenet, openpose, hrnet, ae1-3) work regardless.
RUN bash models/AlphaPose/build_extensions.sh

# Copy entrypoint script
COPY entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

# Set entrypoint
ENTRYPOINT ["/app/entrypoint.sh"]

# Default command
CMD ["python3", "main.py"]
