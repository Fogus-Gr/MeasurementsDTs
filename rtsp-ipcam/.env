# H.264 Streaming Server Environment Configuration

# Server Configuration
SERVER_PORT=8089
# SERVER_HOST=0.0.0.0

# Video Configuration
VIDEO_FILE=/app/videos/hd_00_00.mp4
# VIDEO_QUALITY=ultrafast
# VIDEO_TUNE=zerolatency

# # FFmpeg Configuration
# FFMPEG_PRESET=ultrafast
# FFMPEG_CRF=23
# FFMPEG_MAXRATE=2000k
# FFMPEG_BUFSIZE=4000k

# # Security Configuration
# ENABLE_RATE_LIMITING=true
# MAX_CLIENTS=10
# CLIENT_TIMEOUT=300

# # Logging Configuration
# LOG_LEVEL=INFO
# LOG_FORMAT=json

# # Docker Configuration
# CONTAINER_CPU_LIMIT=1.0
# CONTAINER_MEMORY_LIMIT=512m

# # Production Settings
# ENVIRONMENT=production
# DEBUG=false
