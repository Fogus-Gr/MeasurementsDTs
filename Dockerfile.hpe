FROM pytorch/pytorch:2.4.1-cuda12.1-cudnn9-devel

ENV DEBIAN_FRONTEND=noninteractive
WORKDIR /app

# Create PID directory and set permissions
RUN mkdir -p /pids && chmod 777 /pids

# Copy entrypoint script first and make it executable
COPY entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

# -----------------------------------------------------------------------------------
# SECTION 1: INSTALL BUILD TOOLS AND SYSTEM DEPENDENCIES
# -----------------------------------------------------------------------------------
# Added build-essential, cmake, wget, etc., for compiling from source.
# REMOVED ffmpeg from this list, as we will build it manually.
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    git \
    wget \
    unzip \
    yasm \
    pkg-config \
    libswscale-dev \
    libtbb-dev \
    libjpeg-dev \
    libpng-dev \
    libtiff-dev \
    libavformat-dev \
    libpq-dev \
    gcc-9 g++-9 \
    libgl1-mesa-glx \
    libglib2.0-0 \
    libgomp1 \
    libsm6 \
    libxext6 \
    libxrender-dev \
    libfontconfig1 \
    libice6 \
    curl \
    iputils-ping \
    dnsutils \
    python3-tk \
    tcpdump \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# -----------------------------------------------------------------------------------
# SECTION 2: COMPILE FFMPEG WITH NVIDIA SUPPORT
# -----------------------------------------------------------------------------------
# This version is stable and known to work well.
RUN wget https://ffmpeg.org/releases/ffmpeg-5.1.2.tar.bz2 && \
    tar -xjvf ffmpeg-5.1.2.tar.bz2
WORKDIR /app/ffmpeg-5.1.2
RUN ./configure --enable-shared --enable-nonfree --enable-cuda-nvcc --enable-libnpp \
    --extra-cflags=-I/usr/local/cuda/include --extra-ldflags=-L/usr/local/cuda/lib64 && \
    make -j$(nproc) && make install && ldconfig
WORKDIR /app

# -----------------------------------------------------------------------------------
# SECTION 3: COMPILE OPENCV 4.10.0 WITH CUDA AND FFMPEG SUPPORT
# -----------------------------------------------------------------------------------
RUN wget -O opencv.zip https://github.com/opencv/opencv/archive/4.10.0.zip && \
    wget -O opencv_contrib.zip https://github.com/opencv/opencv_contrib/archive/4.10.0.zip && \
    unzip opencv.zip && unzip opencv_contrib.zip
WORKDIR /app/opencv-4.10.0/build
RUN cmake \
    -D CMAKE_BUILD_TYPE=RELEASE \
    -D CMAKE_INSTALL_PREFIX=/usr/local \
    -D WITH_CUDA=ON \
    -D WITH_CUDNN=ON \
    -D OPENCV_DNN_CUDA=ON \
    -D ENABLE_FAST_MATH=1 \
    -D CUDA_FAST_MATH=1 \
    -D WITH_CUBLAS=1 \
    -D WITH_FFMPEG=ON \
    -D OPENCV_EXTRA_MODULES_PATH=/app/opencv_contrib-4.10.0/modules \
    -D PYTHON_EXECUTABLE=$(which python3) \
    -D BUILD_opencv_python3=ON \
    -D OPENCV_GENERATE_PKGCONFIG=ON \
    .. && \
    make -j$(nproc) && make install && ldconfig
WORKDIR /app

# -----------------------------------------------------------------------------------
# SECTION 4: INSTALL PYTHON DEPENDENCIES AND YOUR APPLICATION
# -----------------------------------------------------------------------------------
# Copy your application files now
COPY . .

# Install dependencies from requirements.txt (which no longer contains opencv-python)
RUN pip3 install --no-cache-dir -r requirements.txt
RUN pip3 install --no-cache-dir gdown

# Install OpenVINO with GPU (NVIDIA) support
RUN pip install --no-cache-dir openvino-dev[onnx,tensorflow2,pytorch,caffe]==2024.2.0

# (Optional) Set OpenVINO environment variables
# ENV OPENVINO_DEVICE=CPU
ENV TORCH_CUDA_ARCH_LIST=8.6

# Create directories and download models (your original commands)
RUN mkdir -p models/OpenVINO/pretrained_models/public/human-pose-estimation-0007/FP32 && \
    mkdir -p models/OpenVINO/pretrained_models/public/human-pose-estimation-0006/FP32 && \
    mkdir -p models/OpenVINO/pretrained_models/public/human-pose-estimation-0005/FP32 && \
    mkdir -p models/OpenVINO/pretrained_models/intel/human-pose-estimation-0001
RUN gdown --id 1p6bi10UybpUIcq5D2XDsgQRLPJIr2RyI -O models/AlphaPose/pretrained_models/fast_res50_256x192.pth && \
    gdown --id 1k-9cUGcdH5ZFN1NcMvZrO0ApW241tboD -O models/AlphaPose/detector/yolo/data/yolov3-spp.weights && \
    gdown --id 15SZwY2jAh1KqHwT-YO6_UByOsQD70RSr -O models/MoveNet/movenet_multipose_lightning_256x256_FP32.bin && \
    gdown --id 1VNucIyIsdaiw1cYt-JGqBWloVu2TVdsm -O models/OpenVINO/pretrained_models/intel/human-pose-estimation-0001/human-pose-estimation-0001.bin && \
    gdown --id 1ZSdsqgD4zUO4gyHMYBfxq3m4UMyQ187j -O models/OpenVINO/pretrained_models/public/human-pose-estimation-0007/FP32/human-pose-estimation-0007.bin && \
    gdown --id 1d8pGQrM9vEfz_oAIey0qRr7Gxp6dS2UE -O models/OpenVINO/pretrained_models/public/human-pose-estimation-0006/FP32/human-pose-estimation-0006.bin && \
    gdown --id 1lEUFqQnWHVymQoZvaXuDFcnOyEEKsexP -O models/OpenVINO/pretrained_models/public/human-pose-estimation-0005/FP32/human-pose-estimation-0005.bin && \
    gdown --id 1fko47eVczJZQb9wWA2X7eQ0TuF4PDXzs -O models/OpenVINO/pretrained_models/public/FP32/higher-hrnet-w32-human-pose-estimation.bin

# Build C/C++/CUDA extensions
RUN bash models/AlphaPose/build_extensions.sh

ENTRYPOINT ["/app/entrypoint.sh"]
CMD ["python3", "main.py"]
