# Example .env for ffmpeg_hpe merged project
SERVER_PORT=8089
VIDEO_FILE=/app/videos/rangeOfMotion/vga_01_01.mp4

# CPU tuning defaults for this 4-vCPU host.
# Compose reads these values automatically; override them locally if needed.
STREAMER_CPUS=1.0
STREAMER_RESERVATION_CPUS=1.0
HPE_CPUS=3.0
OV_MODE=latency
OV_STREAMS=1
OV_THREADS=3
OMP_NUM_THREADS=3
MKL_NUM_THREADS=3
OPENBLAS_NUM_THREADS=3
