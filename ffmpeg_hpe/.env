# Example .env for ffmpeg_hpe merged project
SERVER_PORT=8089
VIDEO_FILE=/videos/rangeOfMotion/vga_01_01.mp4

# CPU tuning defaults for manual compose runs.
# run_experiment_bcc.sh overrides these per host before containers start.
STREAMER_CPUS=1.75
STREAMER_RESERVATION_CPUS=1.5
HPE_CPUS=3.0
HPE_MEMORY_LIMIT=16G
HPE_MEMORY_RESERVATION=12G

OV_MODE=latency
OV_STREAMS=1
OV_THREADS=3
OV_CPU_PINNING=true
OV_HYPER_THREADING=false
OMP_NUM_THREADS=3
MKL_NUM_THREADS=3
OPENBLAS_NUM_THREADS=3
