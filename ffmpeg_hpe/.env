# RTSP pipeline configuration
# MediaMTX broker serves RTSP on port 8554; streamer pushes to /stream path
HPE_INPUT=rtsp://rtsp-broker:8554/stream

# Video file served by the streamer service (relative to ../videos/)
VIDEO_FILE_NAME=vga_01_01.mp4

# GPU configuration
NVIDIA_VISIBLE_DEVICES=all
CUDA_VISIBLE_DEVICES=0

# HPE experiment settings
HPE_METHOD=alphapose
HPE_DEVICE=GPU
